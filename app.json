{
  "expo": {
    "name": "Yaoi",
    "slug": "yaoi-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "../lJCJU57Q_400x400.jpg",
    "scheme": "yaoi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1a1a2e",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yaoi.gymtracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.yaoi.gymtracker"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "../lJCJU57Q_400x400.jpg",
          "color": "#1a1a2e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
